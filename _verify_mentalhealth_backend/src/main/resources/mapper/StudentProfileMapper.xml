<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mentalhealth.mapper.StudentProfileMapper">

    <resultMap id="StudentProfileResultMap" type="com.example.mentalhealth.entity.StudentProfile">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="real_name" property="realName"/>
        <result column="student_no" property="studentNo"/>
        <result column="deleted" property="deleted"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO student_profile (user_id, real_name, student_no, deleted)
        VALUES (#{userId}, #{realName}, #{studentNo}, 0)
    </insert>

    <select id="selectByUserId" resultMap="StudentProfileResultMap">
        SELECT id, user_id, real_name, student_no, deleted, create_time, update_time
        FROM student_profile
        WHERE user_id = #{userId} AND deleted = 0
        LIMIT 1
    </select>

</mapper>
